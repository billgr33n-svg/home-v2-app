# Copy to .env and fill in. .env is gitignored.
# Client-safe values only. Expo inlines EXPO_PUBLIC_* into the app bundle.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secrets NEVER live in this file or the client bundle.
# They belong in Supabase secrets or a server-side env:
#   SUPABASE_SERVICE_ROLE_KEY=
#   DATABASE_URL=
